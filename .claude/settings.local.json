{
  "permissions": {
    "allow": [
      "Bash(npm install:*)",
      "Bash(npm run:*)",
      "Bash(grep -E \"\\\\.\\(ts|tsx\\)$\")",
      "Bash(dir main.js)",
      "Bash(findstr main.js)",
      "Bash(powershell -NoProfile -Command \"\\(Get-Item main.js\\).LastWriteTime\")",
      "Bash(echo \"EXIT=$?\")",
      "Bash(dir styles.css)",
      "Bash(findstr styles *)",
      "Bash(powershell -NoProfile -Command \"\\(Get-Content styles.css | Measure-Object -Line\\).Lines\")",
      "Bash(powershell -NoProfile -Command \"Get-Content styles.css -Tail 10\")",
      "Bash(npx tsc *)"
    ]
  }
}
